# ── Django Core ──────────────────────────────────────────────────────────
# Unique secret key for this Django installation
SECRET_KEY=django-secret-key-here


DEBUG=True # Set to False to disable detailed error pages
ALLOWED_HOSTS=localhost,127.0.0.1 # List of host/domain names that this site can serve

# ── Google OAuth ────────────────────────────────────────────────────────
OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/callback # Google Cloud Project's Console redirect URI

# ── Local LLM (Ollama) ─────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:11434 # The base URL for Ollama (where service is running)
DEFAULT_MODEL=llama3.2 # The default LLM model
